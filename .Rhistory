f5n <- function() {
par(mar = c(1, 1, 1, 1)) # Small, uniform margins
corrplot::corrplot(
cor(df %>% dplyr::select(PS, IC, HP, EV), use = "complete.obs"),
method = "color",
type = "upper",
addCoef.col = "black",
tl.col = "black",
tl.srt = 0,
diag = FALSE,
col = colorRampPalette(c("#7F0000", "red", "#FF7F00", "yellow", "white",
"cyan", "#007FFF", "blue", "#00007F"))(200)
)
}
