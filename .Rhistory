geom_sf(data = CA_c, fill = NA, color = "gray90", linewidth = 0.1) +
annotate("text", x = -120, y = 41,
label = paste0("SI: ",moran_by_class$SI[[i]] %>%
round(2)),
hjust = -0.2, vjust = 1.2, size = 5) +
