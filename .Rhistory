dplyr::select(VAR[[i-1]], climatezone, dac, matches("PV|PS|EV|HP|IC"),wt_ca),
i, future) %>%
mutate(class = paste0(ipt[i],"_",future))
effect <- append(effect, list(f_d))
}
effect
### final adoption by tract
final <- data.frame()
for(i in 1:4){
