dplyr::select(-c("cost_combo_winter_final","cost_combo_summer_final"),
-c("solstor_wtp_dv","ev_wtp_pc","heatpump_wtp_pc","induction_dv","solstor_wtp_dv"),
-c("PS_int","EV_int","HP_int","IC_int"))
### scenario
