for(k in 1:5){
# no sum contrasts
if(k == 1){
da <- data %>%
dplyr::select(VAR[[4]], climatezone, dac, matches("PV|PS|EV|HP|IC", ignore.case = FALSE),wt_ca)
}else{
da <- data %>%
dplyr::select(VAR[[k-1]], climatezone, dac, matches("PV|PS|EV|HP|IC", ignore.case = FALSE),wt_ca)
}
